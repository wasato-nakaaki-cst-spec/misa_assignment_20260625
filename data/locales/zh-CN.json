    },
    "kesennuma": {
      "name": "气仙沼",
      "desc": "面临太平洋的渔业城镇。拥有丰富的新鲜海产品。唐桑半岛的风景名胜不容错过。"
    },
    "zao": {
      "name": "藏王",
      "desc": "藏王回音线和御釜，一个美丽的火山口湖。可以同时享受滑雪和温泉。"
    }
  },
